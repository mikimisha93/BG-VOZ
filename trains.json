<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>BG:voz Live</title>
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.1);
            --glass-border: rgba(255, 255, 255, 0.18);
            --glass-blur: blur(25px);
            --accent-yellow: #FFD700;
            --accent-orange: #FF9500;
            --accent-blue: #007AFF;
            --accent-red: #FF3B30;
            --text-main: #FFFFFF;
            --font-ios: -apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            font-family: var(--font-ios);
            color: var(--text-main);
            height: 100vh; width: 100vw; overflow: hidden;
            background: linear-gradient(-45deg, #050a14, #1a0505, #0a1428, #140514);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
        }

        @keyframes gradientBG { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }

        .page {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            display: flex; flex-direction: column; align-items: center;
            justify-content: flex-start;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            padding-top: 80px;
            padding-bottom: 120px;
            opacity: 0;
            pointer-events: none;
            transform: scale(1.1);
            overflow-y: auto;
        }

        .page.active { opacity: 1; pointer-events: auto; transform: scale(1); }

        /* Monitor UI Styles */
        .monitor-container { width: 100%; padding: 0 25px; display: flex; flex-direction: column; gap: 20px; }
        .picker-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.5; margin-bottom: 8px; }
        
        .styled-select {
            width: 100%; padding: 18px; border-radius: 15px; background: rgba(255,255,255,0.05);
            border: 1px solid var(--glass-border); color: white; font-size: 1rem; outline: none;
            appearance: none; backdrop-filter: var(--glass-blur);
        }

        /* PIDS BOARD */
        .pids-board { width: 100%; background: #000; border: 1px solid #222; border-radius: 15px; overflow: hidden; margin-top: 10px; display: none; }
        .pids-header, .pids-row { display: grid; grid-template-columns: 70px 1fr 100px; padding: 12px 15px; align-items: center; }
        .pids-header { background: #111; border-bottom: 1px solid #222; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; }
        .pids-row { padding: 18px 15px; border-bottom: 1px solid #111; }
        .col-vnum { text-align: left; color: #666; font-family: monospace; font-size: 0.85rem; }
        .col-dir { text-align: left; padding-left: 5px; color: var(--accent-yellow); font-weight: 700; font-size: 0.95rem; text-transform: uppercase; }
        .col-time { text-align: right; color: var(--accent-yellow); font-family: monospace; font-size: 1.2rem; font-weight: bold; }
        .pids-header span { color: #FFFFFF; opacity: 0.6; }

        .blink { animation: blinker 1s linear infinite; }
        @keyframes blinker { 50% { opacity: 0; } }

        /* Navigation & Common */
        .lang-switch { position: absolute; top: env(safe-area-inset-top, 20px); right: 20px; z-index: 1000; font-size: 0.75rem; font-weight: 700; background: var(--glass-bg); padding: 8px 14px; border-radius: 15px; border: 1px solid var(--glass-border); cursor: pointer; backdrop-filter: var(--glass-blur); }
        .nav-bar { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); width: calc(100% - 40px); max-width: 400px; height: 70px; background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid var(--glass-border); border-radius: 35px; display: flex; justify-content: space-around; align-items: center; z-index: 9999; padding: 0 10px; }
        .nav-item { display: flex; flex-direction: column; align-items: center; justify-content: center; color: white; opacity: 0.4; transition: all 0.3s; cursor: pointer; flex: 1; }
        .nav-item.active { opacity: 1; }
        .nav-item svg { width: 24px; height: 24px; margin-bottom: 4px; }
        .nav-item span { font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
        
        .top-section { text-align: center; margin-bottom: 30px; }
        .modern-train-icon { width: 64px; height: 64px; margin-bottom: 10px; }
        h1 { font-size: 2.5rem; font-weight: 800; text-transform: uppercase; }
        .center-section { width: 100%; padding: 0 32px; display: flex; flex-direction: column; gap: 12px; }
        .btn-large { width: 100%; padding: 20px; font-size: 0.8rem; font-weight: 700; border-radius: 20px; border: 1px solid var(--glass-border); background: var(--glass-bg); text-transform: uppercase; text-align: center; }

        /* Planner UI Modern iOS Style */
        .plan-controls { width: 100%; padding: 0 20px; display: flex; flex-direction: column; gap: 10px; position: relative; }
        .input-group { background: var(--glass-bg); border-radius: 20px; border: 1px solid var(--glass-border); overflow: hidden; backdrop-filter: var(--glass-blur); }
        .plan-select { width: 100%; padding: 18px; background: transparent; border: none; color: white; font-size: 1rem; outline: none; appearance: none; }
        .divider { height: 1px; background: var(--glass-border); margin: 0 16px; }
        .swap-btn { position: absolute; right: 35px; top: 50%; transform: translateY(-50%); width: 36px; height: 36px; background: rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 1px solid var(--glass-border); z-index: 10; backdrop-filter: blur(10px); cursor: pointer; }

        .trip-card { background: var(--glass-bg); margin: 12px 20px; border-radius: 20px; border: 1px solid var(--glass-border); overflow: hidden; transition: transform 0.2s ease; }
        .trip-card:active { transform: scale(0.98); }
        .trip-summary { padding: 20px; display: grid; grid-template-columns: 70px 1fr 60px; align-items: center; cursor: pointer; }
        .trip-time { font-family: monospace; font-weight: 800; font-size: 1.2rem; color: var(--accent-yellow); }
        .trip-dest { font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.02em; padding-right: 10px; }
        .trip-vnum { font-family: monospace; font-size: 0.75rem; opacity: 0.4; text-align: right; }
        
        .trip-details { max-height: 0; padding: 0 20px; opacity: 0; overflow: hidden; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); background: rgba(0,0,0,0.15); }
        .trip-card.expanded .trip-details { max-height: 200px; padding: 20px; opacity: 1; border-top: 1px solid var(--glass-border); }
        
        .transfer-badge { display: inline-block; padding: 2px 8px; border-radius: 5px; background: var(--accent-orange); color: black; font-size: 0.6rem; font-weight: 900; margin-bottom: 6px; }
        .line-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; }
    </style>
</head>
<body>

    <div class="lang-switch" onclick="toggleLanguage()" id="langBtn">EN</div>

    <div id="home-page" class="page active">
        <header class="top-section">
            <svg class="modern-train-icon" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                <rect x="5" y="2" width="14" height="16" rx="3"/><line x1="5" y1="12" x2="19" y2="12"/>
                <circle cx="9" cy="15" r="1" fill="white"/><circle cx="15" cy="15" r="1" fill="white"/>
            </svg>
            <h1 id="mainTitle">БГ:ВОЗ</h1>
        </header>
        <main class="center-section">
            <div class="btn-large" id="btnMonitor" onclick="goTo('monitor')">СТАНИЧНИ МОНИТОР</div>
            <div class="btn-large" id="btnPlan" onclick="goTo('plan')">ПЛАНИРАЈ ПУТОВАЊЕ</div>
            <div class="btn-large" id="btnLines" onclick="goTo('lines')">ЛИНИЈЕ</div>
        </main>
    </div>

    <div id="monitor-page" class="page">
        <div class="monitor-container">
            <h2 id="monTitle" style="text-align:center; font-size:1.2rem; letter-spacing:0.1em; text-transform:uppercase;">Station Monitor</h2>
            <div>
                <p class="picker-label" id="selectStationLbl">Select Station</p>
                <select id="stationPicker" class="styled-select" onchange="updatePIDS(this.value)">
                    <option value="" disabled selected hidden id="placeholderOpt">Choose...</option>
                    <optgroup label="LINE 1: WEST ➔ NORTH-EAST" id="groupL1">
                        <option value="batajnica">Batajnica</option>
                        <option value="kamendin">Kamendin</option>
                        <option value="zemun_polje">Zemun Polje</option>
                        <option value="altina">Altina</option>
                        <option value="zemun">Zemun</option>
                        <option value="tosin_bunar">Tošin Bunar</option>
                        <option value="novi_beograd">Novi Beograd</option>
                        <option value="beograd_centar">Beograd Centar (Prokop)</option>
                        <option value="karadjordjev_park">Karađorđev Park</option>
                        <option value="vukov_spomenik">Vukov Spomenik</option>
                        <option value="pancevacki_most">Pančevački Most</option>
                        <option value="krnjaca_most">Krnjača Most</option>
                        <option value="krnjaca">Krnjača</option>
                        <option value="sebes">Sebeš</option>
                        <option value="ovca">Ovča</option>
                    </optgroup>
                    <optgroup label="LINE 2: SOUTH ➔ NORTH-EAST" id="groupL2">
                        <option value="resnik">Resnik</option>
                        <option value="kijevo">Kijevo</option>
                        <option value="knezevac">Kneževac</option>
                        <option value="rakovica">Rakovica</option>
                        <option value="beograd_centar">Beograd Centar (Prokop)</option>
                        <option value="karadjordjev_park">Karađorđev Park</option>
                        <option value="vukov_spomenik">Vukov Spomenik</option>
                        <option value="pancevacki_most">Pančevački Most</option>
                        <option value="krnjaca_most">Krnjača Most</option>
                        <option value="krnjaca">Krnjača</option>
                        <option value="sebes">Sebeš</option>
                        <option value="ovca">Ovča</option>
                    </optgroup>
                </select>
            </div>
            <div id="pidsDisplay" class="pids-board">
                <div class="pids-header">
                    <span class="col-vnum" id="colVnum">Train</span>
                    <span class="col-dir" id="colDir">Direction</span>
                    <span class="col-time" id="colTime">Departure</span>
                </div>
                <div id="pidsBody"></div>
            </div>
        </div>
    </div>

    <div id="plan-page" class="page">
        <div class="plan-controls">
            <div class="input-group">
                <select id="fromPicker" class="plan-select" onchange="runPlanner()">
                    <option value="" disabled selected hidden id="pFrom">Choose Departure...</option>
                </select>
                <div class="divider"></div>
                <select id="toPicker" class="plan-select" onchange="runPlanner()">
                    <option value="" disabled selected hidden id="pTo">Choose Arrival...</option>
                </select>
            </div>
            <button class="swap-btn" onclick="swapStations()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4M7 4L3 8M7 4L11 8M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
            </button>
        </div>
        <div id="plannerResults" style="width: 100%; margin-top: 5px;"></div>
    </div>

    <div id="lines-page" class="page"><h1>Lines</h1></div>

    <nav class="nav-bar">
        <div class="nav-item active" id="nav-home" onclick="goTo('home')">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/></svg>
            <span id="navHomeLabel">Почетна</span>
        </div>
        <div class="nav-item" id="nav-monitor" onclick="goTo('monitor')">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"/></svg>
            <span id="navMonitorLabel">Монитор</span>
        </div>
        <div class="nav-item" id="nav-plan" onclick="goTo('plan')">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12,2C15.31,2 18,4.66 18,7.95C18,12.41 12,19 12,19C12,19 6,12.41 6,7.95C6,4.66 8.69,2 12,2M12,6A2,2 0 0,0 10,8A2,2 0 0,0 12,10A2,2 0 0,0 14,8A2,2 0 0,0 12,6Z"/></svg>
            <span id="navPlanLabel">Пут</span>
        </div>
        <div class="nav-item" id="nav-lines" onclick="goTo('lines')">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.5,18.5L9.5,12.5L13.5,16.5L22,6.91L20.59,5.5L13.5,13.5L9.5,9.5L2,17L3.5,18.5Z"/></svg>
            <span id="navLinesLabel">Линије</span>
        </div>
    </nav>

    <script>
        let currentLang = 'sr'; 
        let trainData = [];

        // Mapping UI IDs to JSON Station Names
        const stationMap = {
            'batajnica': 'Батајница', 'kamendin': 'Камендин', 'zemun_polje': 'Земунско поље',
            'altina': 'Алтина', 'zemun': 'Земун', 'tosin_bunar': 'Тошин бунар',
            'novi_beograd': 'Нови Београд', 'beograd_centar': 'Београд Центар (Dep)',
            'karadjordjev_park': 'Карађорђев парк', 'vukov_spomenik': 'Вуков споменик',
            'pancevacki_most': 'Панчевачки мост', 'krnjaca_most': 'Крњача мост',
            'krnjaca': 'Крњача', 'sebes': 'Себеш', 'ovca': 'Овча',
            'resnik': 'Ресник', 'kijevo': 'Кијево', 'knezevac': 'Кнежевац', 'rakovica': 'Раковица'
        };

        async function loadTrainData() {
            try {
                const response = await fetch('trains.json');
                trainData = await response.json();
            } catch (e) { console.error("Data load error", e); }
        }

        const timeToMin = (t) => {
            if (!t) return 0;
            const [h, m] = t.split(':').map(Number);
            return h * 60 + m;
        };

        // --- STATION MONITOR LOGIC (RESTORED & IMPROVED) ---
        function updatePIDS(stationId) {
            const body = document.getElementById('pidsBody');
            const display = document.getElementById('pidsDisplay');
            const selectedStationName = stationMap[stationId];
            
            display.style.display = 'block';
            
            // Filter trains that stop at this station
            let departures = [];
            trainData.forEach(train => {
                const stop = train.stops.find(s => s.station === selectedStationName);
                if (stop) {
                    departures.push({
                        v: train.train_id,
                        d: train.direction,
                        t: stop.departure
                    });
                }
            });

            // Sort by time
            departures.sort((a, b) => timeToMin(a.t) - timeToMin(b.t));

            if (departures.length === 0) {
                body.innerHTML = `<div class="pids-row"><div class="col-vnum">--</div><div class="col-dir">NO TRAINS FOUND</div><div class="col-time">--:--</div></div>`;
                return;
            }

            body.innerHTML = departures.map(dep => `
                <div class="pids-row">
                    <div class="col-vnum">${dep.v}</div>
                    <div class="col-dir">${dep.d.toUpperCase()}</div>
                    <div class="col-time">${dep.t.replace(':', '<span class="blink">:</span>')}</div>
                </div>
            `).join('');
        }

        // --- TRIP PLANNER LOGIC ---
        function runPlanner() {
            const fromId = document.getElementById('fromPicker').value;
            const toId = document.getElementById('toPicker').value;
            const container = document.getElementById('plannerResults');
            if (!fromId || !toId || fromId === toId) return;

            const fromName = stationMap[fromId];
            const toName = stationMap[toId];
            let possibleTrips = [];

            // 1. DIRECT SEARCH
            trainData.forEach(train => {
                const sIdx = train.stops.findIndex(s => s.station === fromName);
                const eIdx = train.stops.findIndex(s => s.station === toName);
                if (sIdx !== -1 && eIdx !== -1 && sIdx < eIdx) {
                    possibleTrips.push({
                        type: 'direct',
                        depTime: train.stops[sIdx].departure,
                        arrTime: train.stops[eIdx].departure,
                        train1: train,
                        totalMin: timeToMin(train.stops[eIdx].departure) - timeToMin(train.stops[sIdx].departure)
                    });
                }
            });

            // 2. TRANSFER SEARCH (Triangle Nodes)
            const nodes = ["Земун", "Београд Центар (Dep)", "Карађорђев парк"];
            trainData.forEach(t1 => {
                const sIdx = t1.stops.findIndex(s => s.station === fromName);
                if (sIdx === -1) return;

                nodes.forEach(nodeName => {
                    const nIdx = t1.stops.findIndex(s => s.station === nodeName);
                    if (nIdx === -1 || nIdx <= sIdx) return;
                    const arrAtNode = t1.stops[nIdx].departure;
                    
                    trainData.forEach(t2 => {
                        if (t1.train_id === t2.train_id) return;
                        const nStartIdx = t2.stops.findIndex(s => s.station === nodeName);
                        const destIdx = t2.stops.findIndex(s => s.station === toName);

                        if (nStartIdx !== -1 && destIdx !== -1 && nStartIdx < destIdx) {
                            const depFromNode = t2.stops[nStartIdx].departure;
                            const waitTime = timeToMin(depFromNode) - timeToMin(arrAtNode);
                            if (waitTime >= 2 && waitTime <= 60) {
                                possibleTrips.push({
                                    type: 'transfer',
                                    node: nodeName.replace(' (Dep)', ''),
                                    depTime: t1.stops[sIdx].departure,
                                    arrTime: t2.stops[destIdx].departure,
                                    train1: t1,
                                    train2: t2,
                                    totalMin: timeToMin(t2.stops[destIdx].departure) - timeToMin(t1.stops[sIdx].departure)
                                });
                            }
                        }
                    });
                });
            });

            possibleTrips.sort((a, b) => timeToMin(a.arrTime) - timeToMin(b.arrTime));
            renderTrips(possibleTrips.slice(0, 5));
        }

        function renderTrips(trips) {
            const container = document.getElementById('plannerResults');
            if (!trips.length) {
                container.innerHTML = '<p style="text-align:center; opacity:0.5; margin-top:20px;">No routes found.</p>';
                return;
            }
            container.innerHTML = trips.map(trip => {
                const isTrans = trip.type === 'transfer';
                const color = trip.train1.line.includes('1') ? 'var(--accent-blue)' : 'var(--accent-orange)';
                const routeTxt = isTrans ? (currentLang === 'sr' ? `Преседање: ${trip.node}` : `Transfer: ${trip.node}`) : (currentLang === 'sr' ? 'Директно' : 'Direct');
                return `
                    <div class="trip-card" onclick="this.classList.toggle('expanded')">
                        <div class="trip-summary">
                            <div class="trip-time">${trip.depTime}</div>
                            <div class="trip-dest">
                                ${isTrans ? '<span class="transfer-badge">TRANSFER</span><br>' : ''}
                                <span class="line-dot" style="background:${color}"></span>${trip.train1.direction}
                            </div>
                            <div class="trip-vnum">${trip.arrTime}</div>
                        </div>
                        <div class="trip-details">
                            <p style="font-size:0.8rem; opacity:0.8; line-height:1.5;">
                                <b>${routeTxt}</b><br>
                                ${isTrans ? `Voz ${trip.train1.train_id} ➔ ${trip.train2.train_id}` : `Voz ${trip.train1.train_id}`}<br>
                                ${currentLang === 'sr' ? 'Трајање' : 'Duration'}: ${trip.totalMin} min
                            </p>
                        </div>
                    </div>`;
            }).join('');
        }

        // --- COMMON UI FUNCTIONS ---
        function toggleLanguage() {
            currentLang = currentLang === 'sr' ? 'en' : 'sr';
            applyTranslations();
            if(document.getElementById('fromPicker').value) runPlanner();
        }

        function applyTranslations() {
            const t = translations[currentLang];
            document.getElementById('mainTitle').innerText = t.mainTitle;
            document.getElementById('btnMonitor').innerText = t.btnMonitor;
            document.getElementById('btnPlan').innerText = t.btnPlan;
            document.getElementById('btnLines').innerText = t.btnLines;
            document.getElementById('langBtn').innerText = t.langBtn;
            document.getElementById('navHomeLabel').innerText = t.navHome;
            document.getElementById('navMonitorLabel').innerText = t.navMonitor;
            document.getElementById('navPlanLabel').innerText = t.navPlan;
            document.getElementById('navLinesLabel').innerText = t.navLines;
            document.getElementById('monTitle').innerText = t.monTitle;
            document.getElementById('selectStationLbl').innerText = t.selectStationLbl;
            document.getElementById('placeholderOpt').innerText = t.placeholderOpt;
            document.getElementById('groupL1').label = t.groupL1;
            document.getElementById('groupL2').label = t.groupL2;
            document.getElementById('colVnum').innerText = t.colVnum;
            document.getElementById('colDir').innerText = t.colDir;
            document.getElementById('colTime').innerText = t.colTime;
            document.getElementById('pFrom').innerText = t.pFrom;
            document.getElementById('pTo').innerText = t.pTo;
        }

        function goTo(screen) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(screen + '-page').classList.add('active');
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            const nav = document.getElementById('nav-' + screen);
            if(nav) nav.classList.add('active');
        }

        function swapStations() {
            const f = document.getElementById('fromPicker');
            const t = document.getElementById('toPicker');
            const temp = f.value;
            f.value = t.value;
            t.value = temp;
            runPlanner();
        }

        document.addEventListener('DOMContentLoaded', async () => {
            await loadTrainData();
            const list = document.getElementById('stationPicker').innerHTML;
            document.getElementById('fromPicker').innerHTML += list;
            document.getElementById('toPicker').innerHTML += list;
            applyTranslations();
        });
    </script>
</body>
</html>
